# --- Core ---------------------------------------------------------------
# Generate once with: bun --filter @pterodactyl/api run cli environment:setup
APP_KEY=
APP_URL=http://panel.example.com
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_NAME=Pterodactyl

# HTTP port the api listens on.
PORT=3000

# --- Database -----------------------------------------------------------
# DATABASE_URL is preferred; the individual DB_* fields are used by
# migration tooling and the CLI.
DATABASE_URL=mysql://pterodactyl:password@127.0.0.1:3306/panel
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=panel
DB_USERNAME=pterodactyl
DB_PASSWORD=

# --- Redis --------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DATABASE=0

# --- Sessions -----------------------------------------------------------
# Valid drivers: database (uses the existing `sessions` table), redis, memory.
SESSION_DRIVER=database
SESSION_LIFETIME=720
SESSION_COOKIE=pterodactyl_session
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true
SESSION_PATH=/

# --- Hashids -----------------------------------------------------------
HASHIDS_SALT=
HASHIDS_LENGTH=8

# --- Mail ---------------------------------------------------------------
MAIL_HOST=smtp.example.com
MAIL_PORT=25
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Pterodactyl Panel"

# --- Rate limiting ------------------------------------------------------
APP_API_CLIENT_RATELIMIT=256
APP_API_APPLICATION_RATELIMIT=256
