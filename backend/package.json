{
  "name": "pterodactyl-panel-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "db:pull": "bunx prisma db pull",
    "db:generate": "bunx prisma generate",
    "test": "bun test",
    "test:integration": "bun test tests/integration/",
    "test:compat": "bun run tests/compatibility/responseComparer.ts",
    "docker:build": "docker build -t pterodactyl-panel-ts .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "hashids": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.12.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "otplib": "^12.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.3.11",
    "prisma": "^6.6.0",
    "typescript": "^5.7.0"
  }
}
