{
  "name": "pterodactyl-panel",
  "private": true,
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.2.0"
  },
  "scripts": {
    "dev": "turbo run dev --filter=@pterodactyl/api",
    "preview": "turbo run preview --filter=@pterodactyl/api",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "turbo run typecheck",
    "db:generate": "bun --filter @pterodactyl/db run generate",
    "db:migrate": "bun --filter @pterodactyl/db run migrate",
    "db:studio": "bun --filter @pterodactyl/db run studio"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "turbo": "^2.3.0",
    "typescript": "~5.7.0"
  }
}
